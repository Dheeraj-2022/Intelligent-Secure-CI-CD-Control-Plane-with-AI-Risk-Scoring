{
  "dashboard": {
    "id": null,
    "uid": "risk-scoring-v1",
    "title": "AI Risk Scoring Dashboard",
    "description": "Real-time visibility into ML-based CI/CD pipeline risk predictions",
    "tags": ["cicd", "ml", "risk", "ai"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "time": { "from": "now-24h", "to": "now" },

    "templating": {
      "list": [
        {
          "name": "environment",
          "label": "Environment",
          "type": "custom",
          "query": "dev,prod",
          "current": { "text": "dev", "value": "dev" }
        }
      ]
    },

    "panels": [
      {
        "id": 1,
        "title": "Current Risk Score (Latest Build)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "pipeline_risk_score{environment=\"$environment\"}",
            "legendFormat": "Risk Score"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "none",
          "reduceOptions": { "calcs": ["lastNotNull"] }
        },
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green",  "value": null },
            { "color": "yellow", "value": 0.30 },
            { "color": "red",    "value": 0.70 }
          ]
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "decimals": 3,
            "min": 0,
            "max": 1
          }
        }
      },

      {
        "id": 2,
        "title": "Risk Level Distribution (24h)",
        "type": "piechart",
        "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
        "targets": [
          {
            "expr": "sum by (risk_level) (increase(pipeline_builds_by_risk_level_total{environment=\"$environment\"}[24h]))",
            "legendFormat": "{{ risk_level }}"
          }
        ],
        "options": {
          "pieType": "donut",
          "legend": { "displayMode": "table", "placement": "right" }
        }
      },

      {
        "id": 3,
        "title": "Risk Score Trend",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "pipeline_risk_score{environment=\"$environment\"}",
            "legendFormat": "Risk Score"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green",  "value": null },
                { "color": "yellow", "value": 0.30 },
                { "color": "red",    "value": 0.70 }
              ]
            }
          }
        },
        "options": {
          "legend": { "displayMode": "list", "placement": "bottom" },
          "tooltip": { "mode": "single" }
        }
      },

      {
        "id": 4,
        "title": "High-Risk Builds Approved (Overrides)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 4 },
        "targets": [
          {
            "expr": "sum(increase(pipeline_high_risk_deployments_approved_total{environment=\"$environment\"}[24h]))",
            "legendFormat": "Manual Overrides (24h)"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "none",
          "reduceOptions": { "calcs": ["lastNotNull"] }
        },
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green",  "value": null },
            { "color": "yellow", "value": 3 },
            { "color": "red",    "value": 10 }
          ]
        }
      },

      {
        "id": 5,
        "title": "Top Risk Factors (Feature Importance)",
        "type": "bargauge",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "risk_feature_importance",
            "legendFormat": "{{ feature }}"
          }
        ],
        "options": {
          "orientation": "horizontal",
          "reduceOptions": { "calcs": ["mean"] },
          "displayMode": "gradient"
        },
        "fieldConfig": {
          "defaults": { "unit": "short", "min": 0 }
        }
      },

      {
        "id": 6,
        "title": "Model Prediction Accuracy (7d Rolling)",
        "type": "gauge",
        "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "sum(rate(risk_model_correct_predictions_total[7d])) / sum(rate(risk_model_predictions_total[7d])) * 100",
            "legendFormat": "Accuracy %"
          }
        ],
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"] },
          "showThresholdLabels": true
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "red",    "value": null },
                { "color": "yellow", "value": 70 },
                { "color": "green",  "value": 85 }
              ]
            }
          }
        }
      },

      {
        "id": 7,
        "title": "Risk Score vs Actual Failures",
        "type": "scatter",
        "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
        "targets": [
          {
            "expr": "pipeline_risk_score{environment=\"$environment\"} * on(build_number) group_left() pipeline_build_failed{environment=\"$environment\"}",
            "legendFormat": "Failed Builds"
          },
          {
            "expr": "pipeline_risk_score{environment=\"$environment\"} * on(build_number) group_left() (1 - pipeline_build_failed{environment=\"$environment\"})",
            "legendFormat": "Successful Builds"
          }
        ]
      },

      {
        "id": 8,
        "title": "Risk Score Histogram",
        "type": "histogram",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
        "targets": [
          {
            "expr": "pipeline_risk_score{environment=\"$environment\"}",
            "legendFormat": "Risk Score Distribution"
          }
        ],
        "options": {
          "bucketCount": 20,
          "fillOpacity": 80
        }
      },

      {
        "id": 9,
        "title": "Builds by Risk Level Over Time",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
        "targets": [
          {
            "expr": "sum by (risk_level) (rate(pipeline_builds_by_risk_level_total{environment=\"$environment\"}[5m]))",
            "legendFormat": "{{ risk_level }}"
          }
        ],
        "options": {
          "tooltip": { "mode": "multi" }
        },
        "fieldConfig": {
          "overrides": [
            { "matcher": { "id": "byName", "options": "LOW" },    "properties": [{ "id": "color", "value": { "fixedColor": "green",  "mode": "fixed" } }] },
            { "matcher": { "id": "byName", "options": "MEDIUM" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
            { "matcher": { "id": "byName", "options": "HIGH" },   "properties": [{ "id": "color", "value": { "fixedColor": "red",    "mode": "fixed" } }] }
          ]
        }
      }
    ]
  }
}
