{
  "dashboard": {
    "title": "CI/CD Pipeline Metrics",
    "panels": [
      {
        "title": "Pipeline Success Rate",
        "targets": [
          {
            "expr": "sum(rate(jenkins_builds_success_total[5m])) / sum(rate(jenkins_builds_total[5m])) * 100"
          }
        ],
        "type": "stat"
      },
      {
        "title": "Build Duration Trend",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(jenkins_build_duration_seconds_bucket[5m]))"
          }
        ],
        "type": "graph"
      },
      {
        "title": "Failure Reasons",
        "targets": [
          {
            "expr": "sum by (reason) (jenkins_build_failures_total)"
          }
        ],
        "type": "piechart"
      }
    ]
  }
}